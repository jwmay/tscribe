# Generated Xcode project (regenerated from project.yml by XcodeGen)
*.xcodeproj/

# Build output
build/
DerivedData/
.swiftpm/
dist/

# Local test media (recordings kept for manual testing — not tracked)
test-media/

# Bundled engine artifacts (large — copied in at build time, not committed)
Vendor/
*.bin

# ...but DO commit the small engine artifacts used for hermetic + CI builds:
# the whisper-cli binary (~3 MB) and the Silero VAD model (~0.9 MB). The big
# 2.9 GB ggml-large-v3.bin model is still never committed (Full bundles it from
# ~/Developer/whisper.cpp; Lite downloads it at first launch).
!engine/
!engine/whisper-cli
!engine/ggml-silero-v5.1.2.bin

# Speaker-diarization engine (~56 MB) — fetched/built, not committed (like the big
# whisper model). Run scripts/fetch-diarization-engine.sh to obtain these.
engine/sherpa-onnx-offline-speaker-diarization
engine/diarize-segmentation.onnx
engine/diarize-embedding.onnx

# Machine-local Claude Code permissions (the shared commands/ + CLAUDE.md are committed)
.claude/settings.local.json

# macOS / Xcode cruft
.DS_Store
*.xcuserstate
xcuserdata/
